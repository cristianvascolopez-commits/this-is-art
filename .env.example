# ============================
# THIS IS ART - Configuración
# ============================
# Copia este archivo como .env y rellena los valores reales

# Servidor
PORT=3000
NODE_ENV=development

# Claude API (Anthropic)
# Obtén tu clave en: https://console.anthropic.com → API Keys
ANTHROPIC_API_KEY=sk-ant-XXXXXXXXXXXXXXXXXXXXXXXX

# Google Calendar
# 1. Crea un proyecto en https://console.cloud.google.com
# 2. Activa la API de Google Calendar
# 3. Crea una Cuenta de Servicio y descarga el JSON
# 4. Extrae client_email y private_key del JSON
GOOGLE_CLIENT_EMAIL=service-account@tu-proyecto.iam.gserviceaccount.com
GOOGLE_PRIVATE_KEY="-----BEGIN RSA PRIVATE KEY-----\nXXXXXX\n-----END RSA PRIVATE KEY-----"
# 5. Crea un Google Calendar para las citas
# 6. Compártelo con el client_email (rol: "Hacer cambios en eventos")
# 7. Copia el ID del calendario (formato: xxxx@group.calendar.google.com)
GOOGLE_CALENDAR_ID=tu-calendario@group.calendar.google.com

# Configuración del negocio
BUSINESS_NAME=THIS IS ART
BUSINESS_PHONE=93 189 40 78
BUSINESS_ADDRESS=Carrer de Volta, 82, 08224 Terrassa, Barcelona
BOOKSY_URL=https://booksy.com/es-es/117752_this-is-art_barberia_133226_terrassa
FRESHA_URL=https://www.fresha.com

# Horario de trabajo (formato 24h)
OPEN_HOUR=10
CLOSE_HOUR=20
SLOT_DURATION_MINUTES=30

# Rate limiting
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX_REQUESTS=30
